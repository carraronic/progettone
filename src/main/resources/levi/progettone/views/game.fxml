<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="gameScreen" alignment="CENTER" onMouseClicked="#input" prefHeight="768.0" prefWidth="432.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="levi.progettone.controller.GameController">
   <Pane fx:id="level" focusTraversable="true" prefHeight="700.0" prefWidth="432.0">
      <children>
         <ImageView fx:id="player" fitHeight="60.0" fitWidth="60.0" layoutX="186.0" layoutY="244.0" pickOnBounds="true" preserveRatio="true">
            <image>
               <Image url="@../imgs/sprites/yellowbird-midflap.png" />
            </image>
         </ImageView>
         <HBox fx:id="pointCounter" alignment="CENTER" prefHeight="35.0" prefWidth="93.0">
            <children>
               <ImageView fx:id="p3" fitHeight="54.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true" />
               <ImageView fx:id="p2" fitHeight="54.0" fitWidth="36.0" layoutX="10.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true" />
               <ImageView fx:id="p1" fitHeight="54.0" fitWidth="36.0" layoutX="210.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true" />
            </children>
         </HBox>
      </children></Pane>
   <HBox fx:id="piattaforma" alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Button fx:id="back" mnemonicParsing="false" onAction="#goBack" prefHeight="40.0" prefWidth="250.0" text="Go Back">
            <font>
               <Font size="20.0" />
            </font></Button>
      </children>
   </HBox>
</VBox>

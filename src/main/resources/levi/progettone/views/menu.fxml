<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="menuScreen" alignment="CENTER" spacing="20.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="levi.progettone.controller.MenuController">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
  </padding>
   <ImageView fx:id="gameImage" fitHeight="600.0" fitWidth="1700.0" pickOnBounds="true" preserveRatio="true" />
  <Button fx:id="start" onAction="#goStart" text="START" textAlignment="CENTER" />
   <Button fx:id="exit" mnemonicParsing="false" onAction="#esci" text="QUIT" />
   <Label styleClass="spazio">
      <font>
         <Font size="29.0" />
      </font>
   </Label>
   <Label fx:id="author" />
</VBox>
